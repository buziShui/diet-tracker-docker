{
  "name": "diet-tracker",
  "version": "1.0.0",
  "description": "饮食记录 - 语音识别、自动匹配食物热量",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "start": "node server.mjs",
    "preview": "vite preview",
    "cap:init": "cap init",
    "cap:add:android": "cap add android",
    "cap:sync": "npm run build && cap sync",
    "android": "npm run cap:sync && cap open android",
    "android:apk": "npm run cap:sync && cd android && (gradlew.bat assembleDebug 2>nul || gradlew.bat assembleDebug)"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "express": "^4.21.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "capacitor": {
    "appId": "com.diettracker.app",
    "appName": "饮食记录",
    "webDir": "dist"
  }
}
